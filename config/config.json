{
  "entrypoints": {
    "web": {
      "address": ":8080",
      "protocol": "http",
      "middlewares": ["headers", "access-log", "rate-limit", "timeout"]
    },
    "dashboard": {
      "address": ":8081",
      "protocol": "http",
      "middlewares": ["basic-auth"]
    }
  },
  "middlewares": {
    "rate-limit": {
      "type": "rateLimit",
      "config": {
        "requests_per_second": 100,
        "burst": 50
      }
    },
    "basic-auth": {
      "type": "basicAuth",
      "config": {
        "username": "admin",
        "password": "secret"
      }
    },
    "retry": {
      "type": "retry",
      "config": {
        "attempts": 3,
        "initial_interval_ms": 100
      }
    },
    "access-log": {
      "type": "accessLog",
      "config": {
        "file_path": "./logs/access.log"
      }
    },
    "headers": {
      "type": "headers",
      "config": {}
    },
    "timeout": {
      "type": "timeout",
      "config": {
        "high_sec": 5,
        "medium_sec": 10,
        "low_sec": 20
      }
    },
    "circuit-breaker": {
      "type": "circuitBreaker",
      "config": {
        "threshold": 3,
        "recovery_timeout_sec": 15
      }
    },
    "cors": {
      "type": "cors",
      "config": {
        "allowed_origins": ["*"]
      }
    }
  },
  "timeouts": {
    "high_sec": 5,
    "medium_sec": 10,
    "low_sec": 20
  },
  "listen_port": 8080,
  "dashboard_port": 8081,
  "algorithm": "weighted",
  "health_interval_sec": 5,
  "breaker_threshold": 3,
  "breaker_timeout_sec": 15,
  "metrics_interval_sec": 10,
  "max_retries": 3,
  "shutdown_timeout_sec": 15,
  "rate_limit_rps": 100,
  "rate_limit_burst": 200,
  "per_attempt_timeout_sec": 5,
  "retry_backoff_ms": 100,
  "retry_backoff_max_ms": 5000,
  "access_log_path": "./logs/access.log",
  "hot_reload": true,
  "dashboard_auth": {
    "username": "admin",
    "password": "loadbalancer"
  },
  "tls": {
    "enabled": false,
    "cert_file": "server.crt",
    "key_file": "server.key",
    "auto_generate": true
  },
  "cors": {
    "allowed_origins": ["*"]
  },
  "routers": {
    "payment-router": {
      "rule": "PathPrefix('/api/payment') || PathPrefix('/api/checkout')",
      "priority": 100,
      "middlewares": ["rate-limit", "cors", "retry"],
      "service": "fast-backends"
    },
    "admin-router": {
      "rule": "PathPrefix('/admin') && Header('X-Admin-Key', 'secret')",
      "priority": 90,
      "middlewares": ["basic-auth"],
      "service": "admin-backends"
    },
    "default-router": {
      "rule": "PathPrefix('/')",
      "priority": 1,
      "middlewares": ["rate-limit", "retry"],
      "service": "all-backends"
    }
  },
  "services": {
    "fast-backends": {
      "servers": [
        {
          "url": "http://localhost:8001",
          "name": "Alpha-Fast",
          "weight": 5
        }
      ]
    },
    "admin-backends": {
      "servers": [
        {
          "url": "http://localhost:8002",
          "name": "Beta-Admin",
          "weight": 3
        }
      ]
    },
    "all-backends": {
      "servers": [
        {
          "url": "http://localhost:8003",
          "name": "Gamma-All",
          "weight": 1
        },
        {
          "url": "http://localhost:8004",
          "name": "Delta-All",
          "weight": 4
        }
      ]
    }
  },
  "servers": [
    {
      "url": "http://localhost:8001",
      "name": "Alpha",
      "weight": 5,
      "delay_ms": 15,
      "health_check": {
        "path": "/health",
        "interval_sec": 5,
        "timeout_sec": 2,
        "expected_status": 200
      }
    },
    {
      "url": "http://localhost:8002",
      "name": "Beta",
      "weight": 3,
      "delay_ms": 50,
      "health_check": {
        "path": "/health",
        "interval_sec": 10,
        "timeout_sec": 3,
        "expected_status": 200
      }
    },
    {
      "url": "http://localhost:8003",
      "name": "Gamma",
      "weight": 1,
      "delay_ms": 100,
      "health_check": {
        "path": "/health",
        "interval_sec": 15,
        "timeout_sec": 2,
        "expected_status": 200
      }
    },
    {
      "url": "http://localhost:8004",
      "name": "Delta",
      "weight": 4,
      "delay_ms": 20,
      "health_check": {
        "path": "/health",
        "interval_sec": 5,
        "timeout_sec": 2,
        "expected_status": 200
      }
    }
  ]
}
